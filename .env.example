# Public client config used by the static frontend
# Set this to your deployed API endpoint that sends mail via Microsoft Graph
NEXT_PUBLIC_CONTACT_API_URL=

# Teams Live Chat widget config (from Teams admin setup)
NEXT_PUBLIC_TEAMS_LIVE_CHAT_SCRIPT_URL=
NEXT_PUBLIC_TEAMS_LIVE_CHAT_APP_ID=
NEXT_PUBLIC_TEAMS_LIVE_CHAT_ORG_ID=
NEXT_PUBLIC_TEAMS_LIVE_CHAT_ORG_URL=

# Optional fallback if widget is unavailable (for example a Teams deep link)
NEXT_PUBLIC_TEAMS_CHAT_FALLBACK_URL=
